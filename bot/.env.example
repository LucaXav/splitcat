# Copy to .env and fill in. Never commit the real .env.

NODE_ENV=development

# Telegram (from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:AAA...
# Optional but recommended in production: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Public HTTPS URL for the bot's webhook endpoint
# Local: use ngrok and paste the https URL here
# Production: e.g. https://splitcat.yourdomain.com
PUBLIC_URL=https://splitcat.yourdomain.com

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Postgres
DATABASE_URL=postgres://splitcat:password@localhost:5432/splitcat

# Mini App
MINI_APP_URL=https://splitcat-miniapp.vercel.app
# Generate with openssl rand -hex 32; MUST match Mini App's MINI_APP_SECRET
MINI_APP_SECRET=replace-with-32-bytes-hex

# Optional
EXCHANGERATE_API_KEY=

# Server
PORT=3000
TIMEZONE=Asia/Singapore

# Tuning
NUDGE_CHECK_CRON=0 */6 * * *
CLAUDE_VISION_MODEL=claude-opus-4-7
CLAUDE_MEME_MODEL=claude-haiku-4-5-20251001
