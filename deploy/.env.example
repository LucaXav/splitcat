# ---- Copy to deploy/.env and fill in. NEVER commit the real .env. ----

# --- Database ---
# Neon Postgres connection string. Get from https://neon.tech > project > connection details.
DATABASE_URL=

# --- Public URL ---
# Domain you point at this VPS (set an A record before bringing up).
PUBLIC_HOST=splitcat.yourdomain.com
# Full URL (Caddy provides TLS; this should be https)
PUBLIC_URL=https://splitcat.yourdomain.com

# --- Timezone ---
TIMEZONE=Asia/Singapore

# --- Telegram ---
# From @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AAA...
# Generate with: openssl rand -hex 32  — Telegram echoes this back so the
# bot can verify webhook calls actually came from Telegram.
TELEGRAM_WEBHOOK_SECRET=replace-with-32-bytes-hex

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Mini App ---
# The Vercel URL of your deployed Next.js Mini App
MINI_APP_URL=https://splitcat-miniapp.vercel.app
# Generate with: openssl rand -hex 32  — must match Mini App's MINI_APP_SECRET
MINI_APP_SECRET=replace-with-32-bytes-hex

# --- FX (optional) ---
# Free tier of https://www.exchangerate-api.com/ if you want a key.
# Otherwise the bot uses open.er-api.com which is free and no-key.
EXCHANGERATE_API_KEY=

# --- Tuning (optional, sensible defaults) ---
# Cron expression — when to check for due nudges (every 6 hours by default)
NUDGE_CHECK_CRON=0 */6 * * *
# Models. Downgrade vision to claude-sonnet-4-6 to save ~70% on OCR cost.
CLAUDE_VISION_MODEL=claude-opus-4-7
CLAUDE_MEME_MODEL=claude-haiku-4-5-20251001

# Optional: comma-separated Telegram sticker file_ids for nudge memes.
# Bot picks one at random per nudge. Leave empty to send text-only nudges.
# To get file_ids: forward stickers to @RawDataBot in Telegram, copy the file_id field.
NUDGE_STICKER_FILE_IDS=

# Optional: Telegram sticker file_id for the "compliment defense" easter egg.
# Bot sends this sticker when a user excessively flatters the bot.
# Get file_id by forwarding a sticker to @RawDataBot.
FLATTERY_STICKER_FILE_ID=
