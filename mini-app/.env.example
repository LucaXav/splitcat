# Connection string for the same Postgres as the n8n stack.
# If the Mini App is on Vercel and the DB is on your VPS, you'll need to expose
# Postgres on a public port (5432) with TLS + strong password, OR use a
# managed Postgres like Neon/Supabase and point both n8n and the Mini App at it.
DATABASE_URL=postgres://splitcat:password@db.yourdomain.com:5432/splitcat?sslmode=require

# Must match MINI_APP_SECRET in deploy/.env on the VPS.
MINI_APP_SECRET=replace-with-32-bytes-hex

# Used by the server component to call its own API route.
# On Vercel, leave blank (defaults to self). For local dev, set to http://localhost:3000.
NEXT_PUBLIC_APP_URL=
